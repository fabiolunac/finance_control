# URL do banco no Turso (produção), ex: libsql://finance-control-xxx.turso.io
# Para testar localmente contra o finance_control.db original, use: file:../finance_control.db
TURSO_DATABASE_URL=

# Token gerado com `turso db tokens create finance-control` (não precisa em modo file: local)
TURSO_AUTH_TOKEN=

# Token fixo que o frontend deve enviar em "Authorization: Bearer <API_TOKEN>"
API_TOKEN=troque-por-um-token-forte

# Origem permitida por CORS, ex: https://seu-usuario.github.io
ALLOWED_ORIGIN=*

PORT=3000
